NODE_ENV=production

# API
API_PORT=4000
API_BASE_URL=http://localhost:4000
JWT_ACCESS_SECRET=change-me-access-secret-32-chars-minimum-001
JWT_REFRESH_SECRET=change-me-refresh-secret-32-chars-minimum-002
ACCESS_TOKEN_TTL=900
REFRESH_TOKEN_TTL=1209600
COOKIE_DOMAIN=localhost
COOKIE_SECURE=false

# Web
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000
NEXT_PUBLIC_WS_URL=http://localhost:4000/chat

# Signaling
SIGNALING_PORT=4100
SIGNALING_CORS_ORIGIN=http://localhost:3000
SIGNALING_JWT_SECRET=change-me-signaling-jwt-secret-32-char-min
PYTHON_AI_URL=http://localhost:8000
PYTHON_INTERNAL_API_KEY=change-me-internal-api-key-123456

# Data
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/qweb
REDIS_URL=redis://localhost:6379

# Storage
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin
S3_BUCKET=qweb-uploads
S3_QUARANTINE_BUCKET=qweb-quarantine
SIGNED_URL_TTL_SECONDS=300
MAX_UPLOAD_SIZE_BYTES=10485760
CLAMAV_HOST=localhost
CLAMAV_PORT=3310

# Security
CORS_ORIGIN=http://localhost:3000
CSRF_SECRET=change-me-csrf

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
SERVICE_NAME=qweb-api
